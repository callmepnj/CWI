DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"
DATABASE_SSL="true"

# Required for /admin. Use at least 12 characters.
CWI_ADMIN_PASSWORD="change-this-long-admin-password"

# AI_PROVIDER can be openai, gemini, or mock.
# Use mock only for local testing. Production should use openai/gemini with a server-side API key.
AI_PROVIDER="mock"
AI_MODEL=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Public support configuration. Use the real verified UPI ID only in deployment env values.
NEXT_PUBLIC_CWI_UPI_ID=""
NEXT_PUBLIC_CWI_UPI_NAME="Cockroach Watch India"
NEXT_PUBLIC_CWI_UPI_QR_PATH=""

# Optional if you later switch comments to Supabase client libraries.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
