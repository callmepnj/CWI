DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DATABASE_SSL="true"

# Required for /admin. Use at least 12 characters.
CWI_ADMIN_PASSWORD="change-this-long-admin-password"

# AI_PROVIDER can be bedrock, openai, or mock.
# Use mock only for local testing. Production should use bedrock/openai with server-side keys.
AI_PROVIDER="mock"
AI_MODEL=""
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_LIGHT_MODEL=""

# AWS Bedrock. Use AWS credits for heavy newsroom reasoning where possible.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
BEDROCK_MODEL_CLAUDE=""
BEDROCK_MODEL_LLAMA=""
BEDROCK_MODEL_MISTRAL=""

# Optional search discovery. Do not call on every dashboard load.
SERP_API_KEY=""

# Optional if you later switch comments to Supabase client libraries.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
